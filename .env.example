# Fit4Academy — environment variables template.
# Copy to `.env` for local development. DO NOT commit `.env`.
# In production (Railway), set these in the dashboard → Variables tab.

# --- Required in production ---
SECRET_KEY=
DATABASE_URL=

# --- Runtime ---
# FLASK_ENV=production       # set to "production" to enforce secure cookies + SECRET_KEY
# FLASK_DEBUG=               # set to "1" ONLY in local dev; never in production
PORT=8080

# --- SMTP (email) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=                  # optional; defaults to SMTP_USER

# --- Stripe ---
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Square ---
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
SQUARE_ENVIRONMENT=sandbox

# --- Cloudinary ---
CLOUDINARY_URL=

# --- Twilio (SMS) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE=

# --- Anthropic (Marcos AI) ---
ANTHROPIC_API_KEY=
